# Database (shared with HRMS)
DATABASE_URL=postgresql://hrms:Abc1234567!@localhost:5432/hrms

# Redis (for BullMQ)
REDIS_URL=redis://localhost:6379

# Server（本仓库若只跑 HRMS 主服务用 3000；agents-service-v2 单独目录用 3101）
PORT=3000
NODE_ENV=production

# JWT (same secret as HRMS)
JWT_SECRET=your_jwt_secret_here

# LLM Providers
DEEPSEEK_API_KEY=
QWEN_API_KEY=
DOUBAO_API_KEY=

# Feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=

# Push targets
FEISHU_HQ_OPS_CHAT_ID=
FEISHU_ADMIN_CHAT_ID=

# OSS (Alibaba Cloud Object Storage Service) - DISABLED to reduce costs
# OSS_REGION=
# OSS_BUCKET=
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_PUBLIC_BASE_URL=
# OSS_TIMEOUT_MS=
# OSS_PART_SIZE_MB=
# OSS_PARALLEL=
# OSS_RETRY_COUNT=
