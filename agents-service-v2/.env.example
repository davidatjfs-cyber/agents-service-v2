# 复制为 .env 后按需填写

NODE_ENV=development
PORT=3101
ADMIN_PASSWORD=change_me   # 必填，无默认值；缺失时 /api/login 返回 500
DATABASE_URL=postgresql://user:pass@localhost:5432/agents_v2_local
REDIS_URL=redis://localhost:6379
JWT_SECRET=change_me

# ── 自动化总开关：节奏引擎(晨检/巡检/日终/周报)、飞书多维表轮询、KPI 快照、升级扫描、周度评分
ENABLE_AUTOMATIONS=true

# ── MemPalace：营销策划（strategy_agent）是否注入长期记忆；A/B 脚本会切换
# ENABLE_MEMPALACE=true
# MEMPALACE_URL=http://127.0.0.1:3001
# MEMPALACE_DATA_DIR=/opt/mempalace/data/mempalace   # 记忆落盘目录（建议独立卷 + chmod 700）
# MEMPALACE_BEARER_TOKEN=...                         # 若设置，agents 须配 MEMPALACE_HTTP_TOKEN 同值
# MEMPALACE_HTTP_TOKEN=...                           # agents-service 调用 MemPalace 的 Bearer
# MEMPALACE_INTEGRITY_SECRET=...                     # 可选：为 JSONL 行写 HMAC（见 mempalace/SECURITY.md）
# MEMPALACE_HTTP_TIMEOUT_MS=12000
# MEMPALACE_BACKUP_EVERY_WRITES=500
# MEMPALACE_BACKUP_KEEP=14

# ── Wiki 落盘目录（默认 knowledge/wiki）；建议生产单独数据卷
# WIKI_DATA_DIR=/opt/agents-service-v2/data/wiki

# ── Wiki / MemPalace 检索排序：有 DEEPSEEK_API_KEY 时默认走 DeepSeek；显式关闭：KNOWLEDGE_USE_DEEPSEEK=false
# KNOWLEDGE_USE_DEEPSEEK=true

# ── Proactive（定时 anomaly → LLM → agent），默认开启；可逐项关闭
# PROACTIVE_ENABLED=true
# PROACTIVE_USE_LLM=true
# PROACTIVE_INTERVAL_MS=300000
# PROACTIVE_TEST_MODE=true  → LLM 决策桩 + 可与 anomaly-engine 桩联调；生产勿开
# PROACTIVE_MOCK_BRIDGE=true → bridge 不派 agent（与上分离）
# Proactive 决策：默认 DeepSeek，失败自动 Ollama → 规则（普通对话仍走 message-pipeline / Gemma）
# PROACTIVE_LLM_PROVIDER=deepseek
# PROACTIVE_LLM_TIMEOUT_MS=4000
# PROACTIVE_DEEPSEEK_MODEL=deepseek-chat
# PROACTIVE_IMMEDIATE_FIRST=true
# PROACTIVE_LOG=true
# PROACTIVE_DEDUPE_WINDOW_MIN=10

# ── 数据库：默认可写（见 src/utils/db.js）。仅在维护窗口需要只读时二选一：
# ENABLE_DB_READ_ONLY=true
# ENABLE_DB_WRITE=false

# ── 生产环境额外要求（见 src/utils/safety.js）
# APP_ENV=production
# CONFIRM_PRODUCTION=true   # 必填，否则进程启动即 exit(2)
# ENABLE_WEBHOOK=true       # 必填，否则飞书事件/卡片回调全部「回调未启用」，表现为 agents-v2「完全无响应」
# ENABLE_EXTERNAL=true
# ENABLE_LOGIN=true

# ── 飞书多维表：实际毛利率表（默认与同 Base 桌访表共用 app，仅 table_id 可覆盖）
# BITABLE_ACTUAL_MARGIN_APP_ID=
# BITABLE_ACTUAL_MARGIN_APP_SECRET=
# BITABLE_ACTUAL_MARGIN_APP_TOKEN=
# BITABLE_ACTUAL_MARGIN_TABLE_ID=tbl4RTo9ZVTxIpLw

# 异常任务回复多维表（常为 BTA* Base）：须与「拥有该 Base」的自建应用一致，勿与桌访应用混用（否则 99991663）
# 未设置时依次尝试 FEISHU_APP_*、LARK_APP_*、BITABLE_TABLEVISIT_*
# BITABLE_TASK_RESP_APP_ID=
# BITABLE_TASK_RESP_APP_SECRET=

# ── LLM 模型配置（本地优先 + API 兜底）
OLLAMA_BASE_URL=http://100.66.169.37:11434
OLLAMA_OPERATIONS_MODEL=gemma4:26b
OLLAMA_USE_LOCAL_ONLY=true
OLLAMA_LOCAL_FALLBACK=true

# ── 外部 API（可选，本地失败时自动降级使用）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-max
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-2-0-pro-260215

# ── 飞书应用
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=
FEISHU_HQ_OPS_CHAT_ID=
FEISHU_ADMIN_CHAT_ID=
